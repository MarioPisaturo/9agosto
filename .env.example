# Copia questo file in .env e compila i valori reali:
#   cp .env.example .env
#
# In produzione (Netlify) imposta le stesse variabili nel pannello Environment.
# Dopo ogni modifica: riavvia `npm run dev`.

# =============================================================================
# Dropbox (obbligatorio in sviluppo locale)
# =============================================================================
# App key dalla dashboard Dropbox Developers → Settings
VITE_DROPBOX_APP_KEY=your_dropbox_app_key

# Solo sviluppo locale — scade dopo ~4 ore, rigenera da Settings → OAuth 2 → Generate
VITE_DROPBOX_ACCESS_TOKEN=sl.u.your_dropbox_access_token

# Cartella su Dropbox dove salvare le foto (deve iniziare con /)
VITE_DROPBOX_FOLDER=/wedding-photos

# =============================================================================
# Dropbox produzione (Netlify) — refresh token, NON scade
# Esegui: node scripts/dropbox-auth.mjs
# =============================================================================
# DROPBOX_APP_KEY=your_dropbox_app_key
# DROPBOX_APP_SECRET=your_dropbox_app_secret
# DROPBOX_REFRESH_TOKEN=your_refresh_token
# DROPBOX_FOLDER=/wedding-photos

# Opzionale: redirect URI per OAuth (default: origin + /auth/dropbox)
# VITE_DROPBOX_REDIRECT_URI=https://tuodominio.it/auth/dropbox

# =============================================================================
# Protezione tab "Carica" (QR code)
# Documentazione completa: src/config/uploadAccess.ts
# =============================================================================

# false = tutti possono caricare | true = solo chi ha il link/QR con token
VITE_UPLOAD_ACCESS_ENABLED=false

# Nome del parametro in query string
# URL QR esempio: https://tuodominio.it/?upload_key=IL_TUO_TOKEN_SEGRETO
VITE_UPLOAD_ACCESS_PARAM=upload_key

# Token segreto da mettere nel QR code
VITE_UPLOAD_ACCESS_TOKEN=change-me-to-a-secret-token

# Token aggiuntivi accettati (separati da virgola, opzionale)
# VITE_UPLOAD_ACCESS_TOKENS=token-invito-1,token-invito-2

# Valore alternativo per test rapido: ?upload_key=debug
# Usa "*" solo per test (accetta qualsiasi valore)
# VITE_UPLOAD_DEBUG_WILDCARD=debug

# Rimuove ?upload_key=... dall'URL dopo l'accesso (evita re-share del link)
VITE_UPLOAD_STRIP_PARAM=true

# In npm run dev: true = bypassa il controllo QR (comodo per sviluppare)
VITE_UPLOAD_OPEN_IN_DEV=true

# true = galleria + fotocamera | false = solo fotocamera (scatto al momento)
VITE_UPLOAD_GALLERY_ENABLED=true

# =============================================================================
# Debug countdown
# =============================================================================
# In produzione: ?countdown_debug=before|today|celebration|after bypassa sempre la fase reale
# Esempio: https://tuodominio.it/?countdown_debug=celebration

# Abilita anche il pannello UI in produzione (opzionale)
# VITE_COUNTDOWN_DEBUG_ENABLED=true

# Fase iniziale senza query string (solo con pannello abilitato)
# VITE_COUNTDOWN_DEBUG_PHASE=before

# =============================================================================
# Esempi di configurazione
# =============================================================================
#
# Sviluppo libero (nessun QR richiesto in locale):
#   VITE_UPLOAD_ACCESS_ENABLED=false
#   VITE_UPLOAD_OPEN_IN_DEV=true
#
# Matrimonio in produzione (solo QR):
#   VITE_UPLOAD_ACCESS_ENABLED=true
#   VITE_UPLOAD_OPEN_IN_DEV=false
#   VITE_UPLOAD_ACCESS_TOKEN=un-token-lungo-e-random
#
# Protezione attiva ma dev senza QR:
#   VITE_UPLOAD_ACCESS_ENABLED=true
#   VITE_UPLOAD_OPEN_IN_DEV=true
